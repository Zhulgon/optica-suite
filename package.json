{
  "name": "optica-suite",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "start:all": "pnpm demo:setup && pnpm dev",
    "start:fast": "pnpm db:up && pnpm dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:generate": "pnpm --filter api prisma:generate",
    "backup:db": "node scripts/db-backup.js",
    "backup:list": "node scripts/db-backup-list.js",
    "restore:db": "node scripts/db-restore.js",
    "seed:demo": "pnpm --filter api seed:demo",
    "demo:setup": "pnpm db:up && pnpm db:migrate && pnpm db:generate && pnpm seed:demo"
  }
}
