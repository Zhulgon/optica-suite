# Configuracion LAN (sin dominio)
# Cambia LAN_SERVER_IP por la IP fija del equipo servidor en la red local.
LAN_SERVER_IP=192.168.1.50

# Puertos expuestos en el servidor local
WEB_PORT=8080
API_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

# Base de datos
POSTGRES_USER=optica
POSTGRES_PASSWORD=Optica12345
POSTGRES_DB=optica_db

# API
JWT_ACCESS_SECRET=CAMBIAR_ESTE_SECRETO_POR_UNO_MUY_LARGO_Y_SEGURO_123456
JWT_REFRESH_DAYS=7
ADMIN_2FA_ENFORCED=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
ENABLE_SWAGGER=true
ALLOW_PROD_SWAGGER=false
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=20
LOGIN_RATE_LIMIT_EMAIL_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_BLOCK_SECONDS=600
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# URLs publicadas en LAN
WEB_APP_URL=http://192.168.1.50:8080
CORS_ORIGINS=http://192.168.1.50:8080
VITE_API_URL=http://192.168.1.50:3000

# Datos comerciales para comprobante
VITE_BUSINESS_NAME=Optica Suite
VITE_BUSINESS_NIT=NIT 900000000-0
VITE_BUSINESS_PHONE=+57 300 000 0000
VITE_BUSINESS_ADDRESS=Direccion comercial no configurada

# Seed inicial de usuarios
DEMO_SITE_CODE=PRINCIPAL
DEMO_SITE_NAME=Sede Principal
DEMO_EMAIL=admin@optica.local
DEMO_PASSWORD=Admin12345
DEMO_NAME=Administrador
DEMO_ROLE=ADMIN
DEMO_OPTOMETRA_EMAIL=opto@optica.local
DEMO_OPTOMETRA_PASSWORD=Opto12345
DEMO_OPTOMETRA_NAME=Optometra
DEMO_ASESOR_EMAIL=asesor@optica.local
DEMO_ASESOR_PASSWORD=Asesor12345
DEMO_ASESOR_NAME=Asesor

# Correo (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Optica Suite <no-reply@optica.local>
