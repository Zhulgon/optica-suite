# Dominios
APP_DOMAIN=optica.tudominio.com
API_DOMAIN=api.optica.tudominio.com
ACME_EMAIL=ops@tudominio.com

# Base de datos
POSTGRES_USER=optica
POSTGRES_PASSWORD=REEMPLAZAR_PASSWORD_SEGURA
POSTGRES_DB=optica_db

# Seguridad API
JWT_ACCESS_SECRET=REEMPLAZAR_SECRETO_MINIMO_32_CARACTERES
JWT_REFRESH_DAYS=7
ADMIN_2FA_ENFORCED=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_DOMAIN=.tudominio.com
WEB_APP_URL=https://optica.tudominio.com
CORS_ORIGINS=https://optica.tudominio.com
ENABLE_SWAGGER=false
ALLOW_PROD_SWAGGER=false

# Frontend build
VITE_API_URL=https://api.optica.tudominio.com

# Rate limit login
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=20
LOGIN_RATE_LIMIT_EMAIL_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_BLOCK_SECONDS=600

# Correo (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Optica Suite <no-reply@tudominio.com>"
