generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  documentNumber  String   @unique
  phone           String?
  email           String?
  occupation      String?
  birthDate       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  clinicalHistories ClinicalHistory[]
  sales             Sale[]
  labOrders         LabOrder[]

  @@index([documentNumber])
}

model ClinicalHistory {
  id        String   @id @default(uuid())
  patientId String

  // --- Datos generales (del formato)
  visitDate        DateTime @default(now())
  motivoConsulta   String?
  antecedentes     String?

  // --- Lensometría (lentes actuales)
  lens_od_esf  String?
  lens_od_cil  String?
  lens_od_eje  String?
  lens_od_add  String?
  lens_od_vl   String?
  lens_od_vp   String?

  lens_oi_esf  String?
  lens_oi_cil  String?
  lens_oi_eje  String?
  lens_oi_add  String?
  lens_oi_vl   String?
  lens_oi_vp   String?

  // --- Agudeza visual
  av_od_vl String?
  av_od_ph String?
  av_od_vp String?

  av_oi_vl String?
  av_oi_ph String?
  av_oi_vp String?

  // --- Queratometría (como viene en el doc: "41.75/44.75X175")
  ker_od String?
  ker_oi String?

  // --- Estado motor
  motor_vl String?
  motor_vp String?

  // --- Refracción (subjetiva)
  refr_od_esf String?
  refr_od_cil String?
  refr_od_eje String?

  refr_oi_esf String?
  refr_oi_cil String?
  refr_oi_eje String?

  // --- Distancia pupilar (ej: "60/58")
  dp String?

  // --- Corrección óptica final
  rx_od_esf String?
  rx_od_cil String?
  rx_od_eje String?
  rx_od_add String?
  rx_od_vl  String?
  rx_od_vp  String?

  rx_oi_esf String?
  rx_oi_cil String?
  rx_oi_eje String?
  rx_oi_add String?
  rx_oi_vl  String?
  rx_oi_vp  String?

  // --- Segmento posterior
  sp_od String?
  sp_oi String?

  // --- Diagnóstico y conducta
  diagnostico String?
  disposicion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

enum SegmentoMontura {
  DAMA
  HOMBRE
  NINOS
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum SaleStatus {
  ACTIVE
  VOIDED
}

enum DiscountType {
  NONE
  PERCENT
  AMOUNT
}

enum LabOrderStatus {
  PENDING
  SENT_TO_LAB
  RECEIVED
  DELIVERED
  CANCELLED
}

model Frame {
  id           String          @id @default(uuid())
  codigo       Int             @unique
  referencia   String
  segmento     SegmentoMontura
  conPlaqueta  Boolean
  precioVenta  Float
  stockActual  Int             @default(0)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt

  movements    InventoryMovement[]
  saleItems    SaleItem[]
}

model InventoryMovement {
  id        String       @id @default(uuid())
  frameId   String
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  frame     Frame        @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@index([frameId])
  @@index([type])
}

model Sale {
  id            String        @id @default(uuid())
  saleNumber    Int           @unique @default(autoincrement())
  patientId     String?
  paymentMethod PaymentMethod @default(CASH)
  status        SaleStatus    @default(ACTIVE)
  frameSubtotal Float         @default(0)
  lensSubtotal  Float         @default(0)
  subtotal      Float         @default(0)
  discountType  DiscountType  @default(NONE)
  discountValue Float         @default(0)
  discountAmount Float        @default(0)
  taxPercent    Float         @default(0)
  taxAmount     Float         @default(0)
  lensCostTotal Float         @default(0)
  grossProfit   Float         @default(0)
  total         Float
  notes         String?
  voidReason    String?
  voidedAt      DateTime?
  createdAt     DateTime      @default(now())

  patient       Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  items         SaleItem[]
  lensItems     SaleLensItem[]
  labOrders     LabOrder[]
  createdById String?
  createdBy   User? @relation("SalesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  voidedById  String?
  voidedBy    User? @relation("SalesVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([voidedById])
  @@index([status])

  @@index([patientId])
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  frameId   String
  quantity  Int
  unitPrice Float
  subtotal  Float

  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  frame     Frame    @relation(fields: [frameId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([frameId])
}

model SaleLensItem {
  id           String   @id @default(uuid())
  saleId       String
  labOrderId   String?
  description  String
  quantity     Int
  unitSalePrice Float
  unitLabCost  Float
  subtotalSale Float
  subtotalCost Float

  sale      Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  labOrder  LabOrder? @relation(fields: [labOrderId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([labOrderId])
}

enum Role {
  ADMIN
  ASESOR
  OPTOMETRA
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(ASESOR)
  isActive     Boolean  @default(true)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  twoFactorTempSecret String?
  twoFactorEnabledAt DateTime?
  tokenVersion Int      @default(0)
  mustChangePassword Boolean @default(false)
  failedLoginAttempts Int     @default(0)
  lockedUntil        DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  refreshTokens RefreshToken[]
  trustedDeviceTokens TrustedDeviceToken[]
  twoFactorRecoveryCodes TwoFactorRecoveryCode[]
  passwordResetTokens PasswordResetToken[]
  sales         Sale[] @relation("SalesCreatedBy")
  voidedSales   Sale[] @relation("SalesVoidedBy")
  cashClosures  CashClosure[] @relation("CashClosureUser")
  closedCashClosures CashClosure[] @relation("CashClosureClosedBy")
  auditLogs     AuditLog[] @relation("UserAuditLogs")
  createdLabOrders LabOrder[] @relation("LabOrderCreatedBy")
  updatedLabOrders LabOrder[] @relation("LabOrderUpdatedBy")

  @@index([email])
  @@index([role])
  @@index([twoFactorEnabled])
}

model LabOrder {
  id           String         @id @default(uuid())
  patientId    String?
  saleId       String?
  status       LabOrderStatus @default(PENDING)
  reference    String
  lensDetails  String?
  labName      String?
  responsible  String?
  promisedDate DateTime?
  notes        String?
  sentAt       DateTime?
  receivedAt   DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  createdById  String
  updatedById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt

  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  sale      Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  saleLensItems SaleLensItem[]
  createdBy User     @relation("LabOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?    @relation("LabOrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([patientId])
  @@index([saleId])
  @@index([createdById])
  @@index([updatedById])
  @@index([promisedDate])
  @@index([createdAt])
}

model AuditLog {
  id          String    @id @default(uuid())
  actorUserId String?
  actorEmail  String?
  actorRole   Role?
  module      String
  action      String
  entityType  String?
  entityId    String?
  payloadJson Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  actorUser User? @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId])
  @@index([module])
  @@index([action])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  deviceFingerprintHash String?
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([deviceFingerprintHash])
}

model TrustedDeviceToken {
  id                    String   @id @default(uuid())
  userId                String
  tokenHash             String   @unique
  deviceFingerprintHash String
  ipAddress             String?
  userAgent             String?
  expiresAt             DateTime
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  lastUsedAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceFingerprintHash])
  @@index([expiresAt])
  @@index([revokedAt])
}

model TwoFactorRecoveryCode {
  id        String   @id @default(uuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId])
  @@index([usedAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model CashClosure {
  id            String   @id @default(uuid())
  userId        String
  closedById    String
  periodStart   DateTime
  periodEnd     DateTime
  salesCount    Int
  totalSales    Float
  cashSales     Float
  cardSales     Float
  transferSales Float
  mixedSales    Float
  expectedCash  Float
  declaredCash  Float
  difference    Float
  notes         String?
  createdAt     DateTime @default(now())

  user      User @relation("CashClosureUser", fields: [userId], references: [id], onDelete: Restrict)
  closedBy  User @relation("CashClosureClosedBy", fields: [closedById], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([closedById])
  @@index([createdAt])
  @@index([periodStart, periodEnd])
}
